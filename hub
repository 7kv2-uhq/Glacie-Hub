-- ========== VARIABLES PERSISTANTES ==========
local state = {
    Fly = false,
    Noclip = false,
    MurdererESP = false,
    SheriffESP = false,
    AllESP = false,
    GunESP = false,
    CoinESP = false,
    Aimbot = false,
    WalkSpeed = 16,
    JumpPower = 50,
    ESPColor = Color3.fromRGB(255, 0, 0)
}

local espObjects = {
    Murderer = {},
    Sheriff = {},
    All = {},
    Guns = {},
    Coins = {}
}

local bodyVelocity = nil

-- ========== FONCTIONS UTILITAIRES ==========

local function getMurderer()
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= player and v.Character and v.Character:FindFirstChild("Humanoid") then
            if v.Backpack:FindFirstChild("Knife") or v.Character:FindFirstChild("Knife") then
                return v
            end
        end
    end
    return nil
end

local function getSheriff()
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= player and v.Character and v.Character:FindFirstChild("Humanoid") then
            if v.Backpack:FindFirstChild("Gun") or v.Character:FindFirstChild("Gun") then
                return v
            end
        end
    end
    return nil
end

local function getGuns()
    local guns = {}
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("Tool") and v.Name == "Gun" and v.Parent and v.Parent:IsA("Part") then
            table.insert(guns, v)
        end
    end
    return guns
end

local function getCoins()
    local coins = {}
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("Part") and v.Name == "Coin" and v.Parent then
            table.insert(coins, v)
        end
    end
    return coins
end

local function createESP(instance, color, transparency)
    if not instance or not instance.Parent then return nil end
    local highlight = Instance.new("Highlight")
    highlight.Parent = instance
    highlight.FillColor = color or state.ESPColor
    highlight.FillTransparency = transparency or 0.4
    highlight.OutlineColor = color or state.ESPColor
    highlight.OutlineTransparency = 0
    return highlight
end

local function clearESP(tableName)
    for _, v in pairs(espObjects[tableName]) do
        pcall(function() v:Destroy() end)
    end
    espObjects[tableName] = {}
end

local function refreshAllESP()
    -- Murderer
    if state.MurdererESP then
        clearESP("Murderer")
        local murderer = getMurderer()
        if murderer and murderer.Character then
            local h = createESP(murderer.Character, Color3.fromRGB(255,0,0), 0.4)
            if h then table.insert(espObjects.Murderer, h) end
        end
    end
    
    -- Sheriff
    if state.SheriffESP then
        clearESP("Sheriff")
        local sheriff = getSheriff()
        if sheriff and sheriff.Character then
            local h = createESP(sheriff.Character, Color3.fromRGB(0,255,0), 0.4)
            if h then table.insert(espObjects.Sheriff, h) end
        end
    end
    
    -- All players
    if state.AllESP then
        clearESP("All")
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= player and v.Character then
                local h = createESP(v.Character, Color3.fromRGB(255,255,0), 0.3)
                if h then table.insert(espObjects.All, h) end
            end
        end
    end
    
    -- Guns
    if state.GunESP then
        clearESP("Guns")
        for _, gun in pairs(getGuns()) do
            if gun.Parent then
                local h = createESP(gun.Parent, Color3.fromRGB(0,255,255), 0.5)
                if h then table.insert(espObjects.Guns, h) end
            end
        end
    end
    
    -- Coins
    if state.CoinESP then
        clearESP("Coins")
        for _, coin in pairs(getCoins()) do
            if coin.Parent then
                local h = createESP(coin, Color3.fromRGB(255,215,0), 0.5)
                if h then table.insert(espObjects.Coins, h) end
            end
        end
    end
end

-- ========== GESTION DES NOUVEAUX PERSONNAGES ==========

local function setupCharacterListeners()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player then
            p.CharacterAdded:Connect(function()
                refreshAllESP()
            end)
        end
    end
    player.CharacterAdded:Connect(function()
        wait(0.5)
        if player.Character and player.Character:FindFirstChild("Humanoid") then
            player.Character.Humanoid.WalkSpeed = state.WalkSpeed
            player.Character.Humanoid.JumpPower = state.JumpPower
        end
        if state.Noclip and player.Character then
            for _, v in pairs(player.Character:GetChildren()) do
                if v:IsA("BasePart") then
                    v.CanCollide = false
                end
            end
        end
        if state.Fly and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            bodyVelocity = Instance.new("BodyVelocity")
            bodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
            bodyVelocity.Velocity = Vector3.new(0,0,0)
            bodyVelocity.Parent = player.Character.HumanoidRootPart
            player.Character.Humanoid.PlatformStand = true
        end
        refreshAllESP()
    end)
end

Players.PlayerAdded:Connect(function(p)
    p.CharacterAdded:Connect(function()
        refreshAllESP()
    end)
    wait(0.5)
    refreshAllESP()
end)

-- Rafraîchissement périodique
spawn(function()
    while wait(2) do
        if state.MurdererESP or state.SheriffESP or state.AllESP or state.GunESP or state.CoinESP then
            refreshAllESP()
        end
    end
end)

