-- Save Tab
SaveTab:CreateSection("💾 Configuration Management")
SaveTab:CreateParagraph({ Title = "Rayfield Auto‑Save", Content = "Your settings are automatically saved to a local file.\nUse the buttons below to manually save, load, or reset." })

SaveTab:CreateButton({
    Name = "💾 Save Current Config",
    Callback = function()
        if Rayfield.SaveConfiguration then
            Rayfield:SaveConfiguration()
            Rayfield:Notify({ Title = "✅ Saved", Content = "Configuration saved successfully!", Duration = 2 })
        else
            Rayfield:Notify({ Title = "ℹ️ Info", Content = "Auto‑save is always enabled. No manual save needed.", Duration = 2 })
        end
    end
})

SaveTab:CreateButton({
    Name = "📂 Load Config (from file)",
    Callback = function()
        if Rayfield.LoadConfiguration then
            Rayfield:LoadConfiguration()
            for flag, value in pairs(state) do
                pcall(function() Rayfield:SetValue(flag, value) end)
            end
            updatePlayerColors()
            if state.GunESP then scanGuns() end
            Rayfield:Notify({ Title = "✅ Loaded", Content = "Configuration loaded from file!", Duration = 2 })
        else
            Rayfield:Notify({ Title = "ℹ️ Info", Content = "Auto‑load is automatic on script start.", Duration = 2 })
        end
    end
})

SaveTab:CreateButton({
    Name = "🔄 Reset Config to Defaults",
    Callback = function()
        for k, v in pairs(state) do
            if type(v) == "boolean" then
                state[k] = false
                pcall(function() Rayfield:SetValue(k, false) end)
            end
        end
        state.WalkSpeed = 16
        state.JumpPower = 50
        state.ShootKey = "R"
        state.flingTargetName = ""
        pcall(function() Rayfield:SetValue("WalkSpeed", 16) end)
        pcall(function() Rayfield:SetValue("JumpPower", 50) end)
        if player.Character and player.Character.Humanoid then
            player.Character.Humanoid.WalkSpeed = 16
            player.Character.Humanoid.JumpPower = 50
        end
        for _, h in pairs(playerHighlights) do pcall(function() h:Destroy() end) end
        playerHighlights = {}
        for _, h in pairs(gunHighlights) do pcall(function() h:Destroy() end) end
        gunHighlights = {}
        if bodyVelocity then bodyVelocity:Destroy(); bodyVelocity = nil end
        Rayfield:Notify({ Title = "✅ Reset", Content = "All settings reset to default.", Duration = 2 })
    end
})

SaveTab:CreateButton({
    Name = "🔄 Reload Script (Rejoin)",
    Callback = function()
        game:GetService("TeleportService"):Teleport(game.PlaceId, player)
    end
})

