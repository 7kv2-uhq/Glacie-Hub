local state = {
    Fly = false,
    Noclip = false,
    MurdererESP = false,
    SheriffESP = false,
    InnocentESP = false,
    GunESP = false,
    ShootEnabled = false,
    ShootKey = "R",
    WalkSpeed = 16,
