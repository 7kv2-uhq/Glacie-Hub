local function getMurderer()
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= player and v.Character and v.Character:FindFirstChild("Humanoid") then
            if v.Backpack:FindFirstChild("Knife") or v.Character:FindFirstChild("Knife") then
                return v
            end
        end
    end
    return nil
end

local function getSheriff()
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= player and v.Character and v.Character:FindFirstChild("Humanoid") then
            if v.Backpack:FindFirstChild("Gun") or v.Character:FindFirstChild("Gun") then
                return v
            end
        end
    end
    return nil
end

local function getGuns()
    local guns = {}
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("Tool") and (v.Name == "Gun" or string.find(v.Name, "Gun")) then
            if v.Parent and not v.Parent:IsA("Backpack") and not v.Parent:IsA("Model") then
                table.insert(guns, v)
            end
        end
        if v:IsA("Model") and v.Name == "Gun" then
            table.insert(guns, v)
        end
    end
    return guns
end

-- ============================================================
--  FONCTION SHOOT SHERIFF
-- ============================================================
local function shootSheriff()
    -- Vérifier si le joueur a un pistolet
    local gun = player.Backpack:FindFirstChild("Gun") or player.Character:FindFirstChild("Gun")
    if not gun then
        Rayfield:Notify({
            Title = "❌ Pas Sheriff",
            Content = "Tu n'as pas de pistolet !",
            Duration = 2
        })
        return
    end

    -- Trouver le murderer
    local murderer = getMurderer()
    if not murderer or not murderer.Character or not murderer.Character:FindFirstChild("HumanoidRootPart") then
        Rayfield:Notify({
            Title = "❌ Murderer introuvable",
            Content = "Aucun murderer à viser",
            Duration = 2
        })
        return
    end

    -- Équiper le pistolet s'il n'est pas déjà équipé
    if gun.Parent ~= player.Character then
        gun.Parent = player.Character
    end

    -- Vise le murderer (Camera Lock actif ou non, on force le regard)
    local targetPos = murderer.Character.HumanoidRootPart.Position
    workspace.CurrentCamera.CFrame = CFrame.new(workspace.CurrentCamera.CFrame.Position, targetPos)

    -- Tirer : Activer l'outil
    gun:Activate()
    -- Petit délai pour que le tir soit bien pris en compte
    task.wait(0.05)
    gun:Deactivate()

    Rayfield:Notify({
        Title = "🔫 Tir !",
        Content = "Tu as tiré sur " .. murderer.Name,
        Duration = 1
    })
end

