-- === LOGIQUE DE VALIDATION ===
local correct = false

local function validateKey()
    if box.Text == Key then
        correct = true
        -- Animation de sortie
        local fadeOut = TweenService:Create(card, TweenInfo.new(0.2), { BackgroundTransparency = 1 })
        fadeOut:Play()
        local scaleOut = TweenService:Create(scale, TweenInfo.new(0.2), { Scale = 0.85 })
        scaleOut:Play()
        fadeOut.Completed:Connect(function()
            screenGui:Destroy()
        end)
        TweenService:Create(overlay, TweenInfo.new(0.2), { BackgroundTransparency = 1 }):Play()
    else
        err.Text = "❌ Clé incorrecte"
        err.Visible = true
        box.Text = ""
        -- Secousse du champ
        local origPos = box.Position
        for i = 1, 3 do
            TweenService:Create(box, TweenInfo.new(0.05), { Position = origPos + UDim2.new(0.015, 0, 0, 0) }):Play()
            task.wait(0.05)
            TweenService:Create(box, TweenInfo.new(0.05), { Position = origPos - UDim2.new(0.015, 0, 0, 0) }):Play()
            task.wait(0.05)
        end
        TweenService:Create(box, TweenInfo.new(0.05), { Position = origPos }):Play()
    end
end

btn.MouseButton1Click:Connect(validateKey)
box.FocusLost:Connect(function(enter)
    if enter then validateKey() end
end)

-- === ATTENDRE LA CLÉ ===
repeat task.wait() until correct == true
