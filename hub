UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed or not state.Fly then return end
    if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then return end
    local hrp = player.Character.HumanoidRootPart
    local direction = Vector3.new(0,0,0)
    if input.KeyCode == Enum.KeyCode.W then direction = direction + hrp.CFrame.LookVector
    elseif input.KeyCode == Enum.KeyCode.S then direction = direction - hrp.CFrame.LookVector
    elseif input.KeyCode == Enum.KeyCode.A then direction = direction - hrp.CFrame.RightVector
    elseif input.KeyCode == Enum.KeyCode.D then direction = direction + hrp.CFrame.RightVector
    elseif input.KeyCode == Enum.KeyCode.Space then direction = direction + Vector3.new(0,1,0)
    elseif input.KeyCode == Enum.KeyCode.LeftShift then direction = direction - Vector3.new(0,1,0)
    end
    if direction ~= Vector3.new(0,0,0) and bodyVelocity then
        bodyVelocity.Velocity = direction * 50
    end
end)

