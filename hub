-- ============================================
-- ESP OPTIMISÉ (un Highlight par joueur)
-- ============================================
local playerHighlights = {}  -- indexé par joueur
local gunHighlights = {}     -- indexé par l'objet arme

-- Fonction pour obtenir ou créer un Highlight sur un modèle
local function getHighlight(model, color)
    if not model then return nil end
    if not playerHighlights[model] then
        local h = Instance.new("Highlight")
        h.Parent = model
        h.FillTransparency = 0.3
        h.OutlineTransparency = 0
        h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        playerHighlights[model] = h
    end
    return playerHighlights[model]
end

local function clearAllHighlights()
    for model, h in pairs(playerHighlights) do
        pcall(function() h:Destroy() end)
    end
    playerHighlights = {}
    for _, h in pairs(gunHighlights) do
        pcall(function() h:Destroy() end)
    end
    gunHighlights = {}
end

-- Mise à jour intelligente (pas de destruction/création)
local function updateESP()
    if not state.MurdererESP and not state.SheriffESP and not state.InnocentESP and not state.GunESP then
        -- Si tout est désactivé, on nettoie
        clearAllHighlights()
        return
    end

    -- Déterminer les rôles
    local murderer = nil
    local sheriff = nil
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= player and plr.Character and plr.Character.Parent then
            local hasKnife = plr.Backpack:FindFirstChild("Knife") or plr.Character:FindFirstChild("Knife")
            local hasGun = plr.Backpack:FindFirstChild("Gun") or plr.Character:FindFirstChild("Gun")
            if hasKnife then murderer = plr end
            if hasGun then sheriff = plr end
        end
    end

    -- Parcourir tous les joueurs (sauf nous)
    for _, plr in pairs(Players:GetPlayers()) do
        if plr == player then continue end
        local model = plr.Character
        if not model or not model.Parent then
            -- Si le joueur n'a pas de personnage, on nettoie son Highlight s'il existe
            if playerHighlights[plr] then
                pcall(function() playerHighlights[plr]:Destroy() end)
                playerHighlights[plr] = nil
            end
            continue
        end

        local color = nil
        if state.MurdererESP and plr == murderer then
            color = Color3.fromRGB(255,0,0) -- Rouge
        elseif state.SheriffESP and plr == sheriff then
            color = Color3.fromRGB(0,120,255) -- Bleu
        elseif state.InnocentESP and plr ~= murderer and plr ~= sheriff then
            color = Color3.fromRGB(255,200,0) -- Jaune
        end

        if color then
            local h = getHighlight(plr, color)
            if h then
                h.FillColor = color
                h.OutlineColor = color
                h.Enabled = true
            end
        else
            -- Désactiver le Highlight si le joueur n'a pas de rôle à afficher
            if playerHighlights[plr] then
                playerHighlights[plr].Enabled = false
            end
        end
    end

    -- Gestion des armes au sol
    if state.GunESP then
        local guns = {}
        for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("Tool") and v.Name == "Gun" then
                if v.Parent and not v.Parent:IsA("Backpack") and not v.Parent:IsA("Character") then
                    table.insert(guns, v)
                end
            end
        end
        -- Créer/mettre à jour les Highlights des armes
        for _, gun in pairs(guns) do
            if not gunHighlights[gun] then
                local h = Instance.new("Highlight")
                h.Parent = gun
                h.FillColor = Color3.fromRGB(0,255,255)
                h.FillTransparency = 0.3
                h.OutlineColor = Color3.fromRGB(0,255,255)
                h.OutlineTransparency = 0
                h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                gunHighlights[gun] = h
            else
                gunHighlights[gun].Enabled = true
            end
        end
        -- Supprimer les Highlights des armes qui n'existent plus
        for gun, h in pairs(gunHighlights) do
            if not gun.Parent or not table.find(guns, gun) then
                pcall(function() h:Destroy() end)
                gunHighlights[gun] = nil
            end
        end
    else
        -- Nettoyer les armes si désactivé
        for gun, h in pairs(gunHighlights) do
            pcall(function() h:Destroy() end)
        end
        gunHighlights = {}
    end
end

