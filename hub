-- Événements pour forcer une mise à jour
local function onPlayerAdded(plr)
    plr.CharacterAdded:Connect(function()
        task.wait(0.3)
        updateESP()
    end)
end

local function onPlayerRemoving(plr)
    if playerHighlights[plr] then
        pcall(function() playerHighlights[plr]:Destroy() end)
        playerHighlights[plr] = nil
    end
end

for _, plr in pairs(Players:GetPlayers()) do
    if plr ~= player then
        plr.CharacterAdded:Connect(function() task.wait(0.3); updateESP() end)
        plr:GetPropertyChangedSignal("Character"):Connect(function()
            if not plr.Character then
                if playerHighlights[plr] then
                    pcall(function() playerHighlights[plr]:Destroy() end)
                    playerHighlights[plr] = nil
                end
            end
        end)
    end
end
