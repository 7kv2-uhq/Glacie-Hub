local KeySystem = true
local Key = "mm2"

if KeySystem then
    local function AskForKey()
        local screenGui = Instance.new("ScreenGui")
        screenGui.Name = "KeySystem"
        screenGui.Parent = game.Players.LocalPlayer.PlayerGui
        
        local frame = Instance.new("Frame")
        frame.Size = UDim2.new(0, 400, 0, 200)
        frame.Position = UDim2.new(0.5, -200, 0.5, -100)
        frame.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
        frame.BackgroundTransparency = 0.1
        frame.BorderSizePixel = 0
        frame.Parent = screenGui
        
        local title = Instance.new("TextLabel")
        title.Size = UDim2.new(1, 0, 0, 50)
        title.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
        title.Text = "🔑 Entrez la clé"
        title.TextColor3 = Color3.fromRGB(255, 255, 255)
        title.Font = Enum.Font.SourceSansBold
        title.TextSize = 24
        title.Parent = frame
        
        local textBox = Instance.new("TextBox")
        textBox.Size = UDim2.new(0.8, 0, 0, 40)
        textBox.Position = UDim2.new(0.1, 0, 0.3, 0)
        textBox.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
        textBox.TextColor3 = Color3.fromRGB(255, 255, 255)
        textBox.Font = Enum.Font.SourceSans
        textBox.TextSize = 18
        textBox.PlaceholderText = "Entrez la clé..."
        textBox.Text = ""
        textBox.Parent = frame
        
        local validateBtn = Instance.new("TextButton")
        validateBtn.Size = UDim2.new(0.4, 0, 0, 40)
        validateBtn.Position = UDim2.new(0.3, 0, 0.6, 0)
        validateBtn.BackgroundColor3 = Color3.fromRGB(60, 180, 60)
        validateBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        validateBtn.Font = Enum.Font.SourceSans
        validateBtn.TextSize = 18
        validateBtn.Text = "Valider"
        validateBtn.Parent = frame
        
        local result = nil
        
        validateBtn.MouseButton1Click:Connect(function()
            local input = textBox.Text
            if input == Key then
                result = true
                screenGui:Destroy()
            else
                local errorLabel = Instance.new("TextLabel")
                errorLabel.Size = UDim2.new(1, 0, 0, 30)
                errorLabel.Position = UDim2.new(0, 0, 0.8, 0)
                errorLabel.BackgroundTransparency = 1
                errorLabel.Text = "❌ Clé incorrecte !"
                errorLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
                errorLabel.Font = Enum.Font.SourceSansBold
                errorLabel.TextSize = 18
                errorLabel.Parent = frame
                textBox.Text = ""
            end
        end)
        
        repeat
            wait()
        until result ~= nil
        
        return result
    end
    
    local correct = AskForKey()
    if not correct then
        print("❌ Clé incorrecte, arrêt du script")
        return
    end
    print("✅ Clé correcte ! Chargement...")
end

