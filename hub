-- ============================================================
local function createESP(instance, color, transparency, outlineColor)
    if not instance or not instance.Parent then return nil end
    local highlight = Instance.new("Highlight")
    highlight.Parent = instance
    highlight.FillColor = color
    highlight.FillTransparency = transparency or 0.3
    highlight.OutlineColor = outlineColor or color
    highlight.OutlineTransparency = 0
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    return highlight
end

local function clearESP(tableName)
    for _, v in pairs(espObjects[tableName]) do
        pcall(function() v:Destroy() end)
    end
    espObjects[tableName] = {}
end

local function refreshAllESP()
    if state.MurdererESP then
        clearESP("Murderer")
        local murderer = getMurderer()
        if murderer and murderer.Character then
            local target = murderer.Character:FindFirstChild("Head") or murderer.Character
            local h = createESP(target, state.MurdererColor, 0.25, Color3.fromRGB(255, 200, 200))
            if h then table.insert(espObjects.Murderer, h) end
        end
    end
    
    if state.SheriffESP then
        clearESP("Sheriff")
        local sheriff = getSheriff()
        if sheriff and sheriff.Character then
            local target = sheriff.Character:FindFirstChild("Head") or sheriff.Character
            local h = createESP(target, state.SheriffColor, 0.25, Color3.fromRGB(200, 200, 255))
            if h then table.insert(espObjects.Sheriff, h) end
        end
    end
    
    if state.AllESP then
        clearESP("All")
        local murderer = getMurderer()
        local sheriff = getSheriff()
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= player and v.Character and v ~= murderer and v ~= sheriff then
                local target = v.Character:FindFirstChild("Head") or v.Character
                local h = createESP(target, state.InnocentColor, 0.2, Color3.fromRGB(255, 230, 150))
                if h then table.insert(espObjects.All, h) end
            end
        end
    end
    
    if state.GunESP then
        clearESP("Guns")
        for _, gun in pairs(getGuns()) do
            if gun and gun.Parent then
                local target = gun
                if gun:IsA("Tool") and gun.Parent and gun.Parent:IsA("Model") then
                    target = gun.Parent
                end
                local h = createESP(target, Color3.fromRGB(0, 255, 255), 0.4, Color3.fromRGB(150, 255, 255))
                if h then table.insert(espObjects.Guns, h) end
            end
        end
    end
end

spawn(function()
    while wait(3) do
        if state.MurdererESP or state.SheriffESP or state.AllESP or state.GunESP then
            refreshAllESP()
        end
    end
end)

local function setupCharacterListeners()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player then
            p.CharacterAdded:Connect(function() 
                wait(0.5)
                refreshAllESP() 
            end)
        end
    end
    player.CharacterAdded:Connect(function()
        wait(0.5)
        if player.Character and player.Character:FindFirstChild("Humanoid") then
            player.Character.Humanoid.WalkSpeed = state.WalkSpeed
            player.Character.Humanoid.JumpPower = state.JumpPower
        end
        if state.Noclip and player.Character then
            for _, v in pairs(player.Character:GetChildren()) do
                if v:IsA("BasePart") then v.CanCollide = false end
            end
        end
        if state.Fly and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            bodyVelocity = Instance.new("BodyVelocity")
            bodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
            bodyVelocity.Velocity = Vector3.new(0,0,0)
            bodyVelocity.Parent = player.Character.HumanoidRootPart
            player.Character.Humanoid.PlatformStand = true
        end
        refreshAllESP()
    end)
end

