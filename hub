ESPTab:CreateToggle({
    Name = "🔴 ESP Murderer", CurrentValue = false, Flag = "MurdererESP",
    Callback = function(v) state.MurdererESP = v; updatePlayerColors() end
})
ESPTab:CreateToggle({
    Name = "🔵 ESP Sheriff", CurrentValue = false, Flag = "SheriffESP",
    Callback = function(v) state.SheriffESP = v; updatePlayerColors() end
})
ESPTab:CreateToggle({
    Name = "🟡 ESP Innocents", CurrentValue = false, Flag = "InnocentESP",
    Callback = function(v) state.InnocentESP = v; updatePlayerColors() end
})
ESPTab:CreateToggle({
    Name = "🔫 ESP Armes (cyan)", CurrentValue = false, Flag = "GunESP",
    Callback = function(v)
        state.GunESP = v
        if v then scanGuns()
        else
            for obj, h in pairs(gunHighlights) do pcall(function() h:Destroy() end) end
            gunHighlights = {}
        end
    end
})

-- Combat
CombatTab:CreateSection("🔫 Tir automatique")
CombatTab:CreateToggle({
    Name = "🎯 Activer le tir",
    CurrentValue = false,
    Flag = "ShootToggle",
    Callback = function(v)
        state.ShootEnabled = v
        Rayfield:Notify({ Title = "Tir", Content = v and "✅ Activé (touche "..state.ShootKey..")" or "❌ Désactivé", Duration = 2 })
    end
})
CombatTab:CreateInput({
    Name = "⌨️ Touche de tir",
    PlaceholderText = "R",
    RemoveTextAfterFocusLost = false,
    Callback = function(t)
        local key = string.upper(string.sub(t, 1, 1))
        if key:match("%a") then
            state.ShootKey = key
            Rayfield:Notify({ Title = "Touche", Content = "Touche : " .. key, Duration = 2 })
        end
    end
})

-- Monde
WorldTab:CreateSection("📍 Téléportation")
WorldTab:CreateButton({ Name = "🎯 Au Murderer", Callback = function()
    local m = getMurderer()
    if m and m.Character and m.Character:FindFirstChild("HumanoidRootPart") then
        player.Character.HumanoidRootPart.Position = m.Character.HumanoidRootPart.Position + Vector3.new(0,3,0)
    end
end })
WorldTab:CreateButton({ Name = "🎯 Au Sheriff", Callback = function()
    local s = nil
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= player and v.Character then
            if v.Backpack:FindFirstChild("Gun") or v.Character:FindFirstChild("Gun") then s = v; break end
        end
    end
    if s and s.Character and s.Character:FindFirstChild("HumanoidRootPart") then
        player.Character.HumanoidRootPart.Position = s.Character.HumanoidRootPart.Position + Vector3.new(0,3,0)
    end
end })
WorldTab:CreateButton({ Name = "🏠 Lobby", Callback = function()
    local lobby = workspace:FindFirstChild("Lobby") or workspace:FindFirstChild("LobbySpawn")
    local pos = (lobby and lobby:FindFirstChild("HumanoidRootPart") and lobby.HumanoidRootPart.Position + Vector3.new(0,5,0)) or Vector3.new(0,50,0)
    if player.Character then player.Character.HumanoidRootPart.Position = pos end
end })
WorldTab:CreateButton({ Name = "🗺️ Map", Callback = function()
    local map = workspace:FindFirstChild("Map") or workspace:FindFirstChild("Game")
    local pos = (map and map:FindFirstChild("HumanoidRootPart") and map.HumanoidRootPart.Position + Vector3.new(0,5,0)) or Vector3.new(0,100,0)
    if player.Character then player.Character.HumanoidRootPart.Position = pos end
end })

-- Divers
MiscTab:CreateSection("💥 Fling")
MiscTab:CreateButton({ Name = "🔪 Fling Murderer", Callback = function() flingPlayer(getMurderer()) end })
MiscTab:CreateButton({ Name = "🔫 Fling Sheriff", Callback = function()
    local s = nil
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= player and v.Character then
            if v.Backpack:FindFirstChild("Gun") or v.Character:FindFirstChild("Gun") then s = v; break end
        end
    end
    flingPlayer(s)
end })
MiscTab:CreateInput({ Name = "👤 Nom du joueur", PlaceholderText = "Pseudo...", Flag = "FlingTargetInput",
    Callback = function(t) state.flingTargetName = t end
})
MiscTab:CreateButton({ Name = "💥 Fling ce joueur", Callback = function()
    local target = Players:FindFirstChild(state.flingTargetName)
    if target then flingPlayer(target) else Rayfield:Notify({ Title = "❌", Content = "Introuvable", Duration = 2 }) end
end })

MiscTab:CreateSection("🔄 Utilitaires")
MiscTab:CreateButton({ Name = "🔄 Reset", Callback = function() if player.Character then player.Character:BreakJoints() end end })
MiscTab:CreateButton({ Name = "❤️ Soin", Callback = function() if player.Character and player.Character.Humanoid then player.Character.Humanoid.Health = player.Character.Humanoid.MaxHealth end end })
MiscTab:CreateButton({ Name = "🔄 Rejoin", Callback = function() game:GetService("TeleportService"):Teleport(game.PlaceId, player) end })

-- Paramètres
SettingsTab:CreateSection("⚙️")
SettingsTab:CreateButton({ Name = "❌ Fermer", Callback = function() Window:Destroy() end })
SettingsTab:CreateButton({
    Name = "🔄 Réinitialiser tout",
    Callback = function()
        for k, v in pairs(state) do
            if type(v) == "boolean" then
                state[k] = false
                pcall(function() Rayfield:SetValue(k, false) end)
            end
        end
        state.WalkSpeed = 16
        state.JumpPower = 50
        if player.Character and player.Character.Humanoid then
            player.Character.Humanoid.WalkSpeed = 16
            player.Character.Humanoid.JumpPower = 50
        end
        for _, h in pairs(playerHighlights) do pcall(function() h:Destroy() end) end
        playerHighlights = {}
        for _, h in pairs(gunHighlights) do pcall(function() h:Destroy() end) end
        gunHighlights = {}
        if bodyVelocity then bodyVelocity:Destroy(); bodyVelocity = nil end
        Rayfield:Notify({ Title = "✅", Content = "Réinitialisé", Duration = 2 })
    end
})

